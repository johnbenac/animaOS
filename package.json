{
  "name": "anima",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter '*' dev",
    "dev:api": "bun --filter api dev",
    "dev:desktop": "bun --filter desktop dev",
    "build": "bun --filter '*' build",
    "lint": "bun --filter '*' lint",
    "data:nuke": "bash ./scripts/nuke-dev-data.sh --yes",
    "data:nuke:reinit": "bash ./scripts/nuke-dev-data.sh --yes --migrate",
    "db:push": "bun --filter api db:push",
    "db:studio": "bun --filter api db:studio"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
