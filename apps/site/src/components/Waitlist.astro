---
import WaitlistForm from "./WaitlistForm.tsx";
---

<section class="py-24 px-6 border-t border-border/50">
  <div class="mx-auto max-w-xl text-center reveal">
    <p class="font-serif italic text-xl sm:text-2xl text-text leading-snug mb-8">
      This is early. Come build with us.
    </p>

    <WaitlistForm client:visible />

    <p class="mt-3 font-mono text-[9px] tracking-[0.3em] uppercase text-text-muted/40">
      No spam. Just updates when it matters.
    </p>
  </div>
</section>
