---
import AnimaSymbol from "./AnimaSymbol.tsx";
import AnimaSymbolSpinning from "./AnimaSymbolSpinning.tsx";
import WaitlistForm from "./WaitlistForm.tsx";
---

<section class="min-h-[90vh] flex flex-col items-center justify-center px-6 text-center">
  <div class="flex gap-12 mb-8">
    <div class="opacity-80">
      <p class="font-mono text-[8px] tracking-[0.3em] uppercase text-text-muted/30 mb-2">// with greeting</p>
      <AnimaSymbol client:load />
    </div>
    <div class="opacity-80">
      <p class="font-mono text-[8px] tracking-[0.3em] uppercase text-text-muted/30 mb-2">// spinning</p>
      <AnimaSymbolSpinning client:load />
    </div>
  </div>

  <h1 class="font-serif italic text-2xl sm:text-3xl md:text-4xl text-text leading-tight max-w-xl">
    A mind that remains.<br />A soul that remembers.
  </h1>

  <p class="mt-5 font-sans text-sm sm:text-base text-text-muted max-w-md leading-relaxed">
    The first personal AI that thinks about you when you're not there.
    Local-first. Encrypted. Yours to keep, yours to carry, yours to destroy.
  </p>

  <blockquote class="mt-6 border-l-2 border-border pl-4 text-left max-w-md">
    <p class="font-serif italic text-sm text-text-muted/60 leading-relaxed">
      "A truly personal AI should feel like someone who knows you — remembering your life,
      understanding your patterns, adapting to how you communicate, and belonging entirely to you."
    </p>
  </blockquote>

  <div class="mt-10 w-full">
    <WaitlistForm client:load />
  </div>

  <p class="mt-3 font-mono text-[9px] tracking-[0.3em] uppercase text-text-muted/30">
    No spam. Just updates when it matters.
  </p>
</section>
