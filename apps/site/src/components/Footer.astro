---
const year = new Date().getFullYear();
---

<footer class="border-t border-border/50 py-8 mt-24">
  <div class="mx-auto max-w-5xl px-5">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="font-mono text-[8px] tracking-[0.3em] uppercase text-text-muted/20">
        &copy; {year} AnimaOS
      </p>
      <div class="flex items-center gap-6">
        <a href="/blog" class="font-mono text-[8px] tracking-[0.2em] uppercase text-text-muted/30 hover:text-text/60 transition-colors">Blog</a>
        <a href="/docs" class="font-mono text-[8px] tracking-[0.2em] uppercase text-text-muted/30 hover:text-text/60 transition-colors">Docs</a>
        <a href="https://github.com/juliocaesar/animaOS" target="_blank" rel="noopener noreferrer" class="font-mono text-[8px] tracking-[0.2em] uppercase text-text-muted/30 hover:text-text/60 transition-colors">GitHub</a>
      </div>
    </div>
    <p class="text-center mt-6 font-serif italic text-text-muted/20 text-xs">
      The only intelligence that was never anyone else's.
    </p>
  </div>
</footer>
