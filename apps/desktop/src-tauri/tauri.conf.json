{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ANIMA",
  "version": "0.1.0",
  "identifier": "com.leoca.anima",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run prepare:release && bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ANIMA",
        "width": 900,
        "height": 700,
        "label": "main"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' http://127.0.0.1:3031 http://localhost:3031 https://translate.googleapis.com; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "bin/": "bin/",
      "../../api/prompts/": "prompts/",
      "../../api/drizzle/": "drizzle/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
